{
  "name": "@clawdev/server",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/jcafeitosa/ClawDev",
  "bugs": {
    "url": "https://github.com/jcafeitosa/ClawDev/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jcafeitosa/ClawDev",
    "directory": "server"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./eden-treaty": "./src/eden-treaty.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./eden-treaty": {
        "types": "./dist/eden-treaty.d.ts",
        "import": "./dist/eden-treaty.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:node": "bunx tsx src/index.ts",
    "dev:watch": "cross-env CLAWDEV_MIGRATION_PROMPT=never CLAWDEV_MIGRATION_AUTO_APPLY=true bun run ./scripts/dev-watch.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc && mkdir -p dist/onboarding-assets && cp -R src/onboarding-assets/. dist/onboarding-assets/",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "bun run dist/index.js",
    "typecheck": "pnpm --filter @clawdev/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@clawdev/adapter-claude-local": "workspace:*",
    "@clawdev/adapter-codex-local": "workspace:*",
    "@clawdev/adapter-copilot-local": "workspace:*",
    "@clawdev/adapter-cursor-local": "workspace:*",
    "@clawdev/adapter-gemini-local": "workspace:*",
    "@clawdev/adapter-openai-compatible-local": "workspace:*",
    "@clawdev/adapter-openclaw-gateway": "workspace:*",
    "@clawdev/adapter-opencode-local": "workspace:*",
    "@clawdev/adapter-pi-local": "workspace:*",
    "@clawdev/adapter-utils": "workspace:*",
    "@clawdev/db": "workspace:*",
    "@clawdev/plugin-sdk": "workspace:*",
    "@clawdev/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.6.0",
    "bullmq": "^5.73.0",
    "chokidar": "^5.0.0",
    "detect-port": "^2.1.0",
    "dompurify": "^3.4.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "embedded-postgres": "18.3.0-beta.16",
    "ioredis": "^5.10.1",
    "jsdom": "^29.0.2",
    "open": "^11.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "ws": "^8.20.0"
  }
}
