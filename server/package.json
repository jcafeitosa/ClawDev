{
  "name": "@clawdev/server",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/paperclipai/paperclip",
  "bugs": {
    "url": "https://github.com/paperclipai/paperclip/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paperclipai/paperclip",
    "directory": "server"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "ui-dist",
    "skills"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:node": "tsx src/index.ts",
    "dev:watch": "cross-env PAPERCLIP_MIGRATION_PROMPT=never PAPERCLIP_MIGRATION_AUTO_APPLY=true bun run ./scripts/dev-watch.ts",
    "prepare:ui-dist": "bash ../scripts/prepare-server-ui-dist.sh",
    "build": "tsc && mkdir -p dist/onboarding-assets && cp -R src/onboarding-assets/. dist/onboarding-assets/",
    "prepack": "pnpm run prepare:ui-dist",
    "postpack": "rm -rf ui-dist",
    "clean": "rm -rf dist",
    "start": "bun run dist/index.js",
    "typecheck": "pnpm --filter @clawdev/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@clawdev/adapter-claude-local": "workspace:*",
    "@clawdev/adapter-codex-local": "workspace:*",
    "@clawdev/adapter-cursor-local": "workspace:*",
    "@clawdev/adapter-gemini-local": "workspace:*",
    "@clawdev/adapter-openclaw-gateway": "workspace:*",
    "@clawdev/adapter-opencode-local": "workspace:*",
    "@clawdev/adapter-pi-local": "workspace:*",
    "@clawdev/adapter-utils": "workspace:*",
    "@clawdev/db": "workspace:*",
    "@clawdev/plugin-sdk": "workspace:*",
    "@clawdev/shared": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/static": "^1.4.7",
    "@elysiajs/swagger": "^1.3.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-auth": "1.4.18",
    "bullmq": "^5.71.1",
    "chokidar": "^4.0.3",
    "detect-port": "^2.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.4",
    "elysia": "^1.4.28",
    "embedded-postgres": "18.1.0-beta.16",
    "hermes-paperclip-adapter": "0.1.1",
    "ioredis": "^5.10.1",
    "jsdom": "^28.1.0",
    "open": "^11.0.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^24.12.0",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "ws": "^8.20.0"
  }
}
