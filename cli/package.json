{
  "name": "clawdev",
  "version": "0.3.1",
  "description": "ClawDev CLI \u2014 orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "clawdev": "./dist/index.js"
  },
  "keywords": [
    "clawdev",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jcafeitosa/ClawDev",
    "directory": "cli"
  },
  "homepage": "https://github.com/jcafeitosa/ClawDev",
  "bugs": {
    "url": "https://github.com/jcafeitosa/ClawDev/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun --eval \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@clawdev/adapter-claude-local": "workspace:*",
    "@clawdev/adapter-codex-local": "workspace:*",
    "@clawdev/adapter-cursor-local": "workspace:*",
    "@clawdev/adapter-gemini-local": "workspace:*",
    "@clawdev/adapter-openclaw-gateway": "workspace:*",
    "@clawdev/adapter-opencode-local": "workspace:*",
    "@clawdev/adapter-pi-local": "workspace:*",
    "@clawdev/adapter-utils": "workspace:*",
    "@clawdev/db": "workspace:*",
    "@clawdev/server": "workspace:*",
    "@clawdev/shared": "workspace:*",
    "@elysiajs/eden": "^1.4.9",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "0.45.2",
    "embedded-postgres": "18.3.0-beta.16",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
