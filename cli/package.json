{
  "name": "clawdev",
  "version": "0.3.1",
  "description": "ClawDev CLI — orchestrate AI agent teams to run a business",
  "type": "module",
  "bin": {
    "clawdev": "./dist/index.js"
  },
  "keywords": [
    "clawdev",
    "ai",
    "agents",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jcafeitosa/ClawDev",
    "directory": "cli"
  },
  "homepage": "https://github.com/jcafeitosa/ClawDev",
  "bugs": {
    "url": "https://github.com/jcafeitosa/ClawDev/issues"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "node --input-type=module -e \"import esbuild from 'esbuild'; import config from './esbuild.config.mjs'; await esbuild.build(config);\" && chmod +x dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "@clawdev/adapter-claude-local": "workspace:*",
    "@clawdev/adapter-codex-local": "workspace:*",
    "@clawdev/adapter-cursor-local": "workspace:*",
    "@clawdev/adapter-gemini-local": "workspace:*",
    "@clawdev/adapter-openclaw-gateway": "workspace:*",
    "@clawdev/adapter-opencode-local": "workspace:*",
    "@clawdev/adapter-pi-local": "workspace:*",
    "@clawdev/adapter-utils": "workspace:*",
    "@clawdev/db": "workspace:*",
    "@clawdev/server": "workspace:*",
    "@clawdev/shared": "workspace:*",
    "commander": "^13.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "0.38.4",
    "embedded-postgres": "18.1.0-beta.16",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
