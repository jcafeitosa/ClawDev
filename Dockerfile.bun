# ============================================================
# ClawDev — Bun-based production Dockerfile
# ============================================================
# Multi-stage build:
#   1. deps   — install dependencies
#   2. build  — compile TypeScript + bundle UI
#   3. prod   — minimal runtime image
# ============================================================

FROM oven/bun:1.2-alpine AS base
RUN apk add --no-cache ca-certificates curl git

# ============================================================
# Stage 1: Install dependencies
# ============================================================
FROM base AS deps
WORKDIR /app

COPY package.json bun.lock pnpm-workspace.yaml .npmrc ./
COPY cli/package.json cli/
COPY server/package.json server/
COPY svelte-ui/package.json svelte-ui/
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/adapter-utils/package.json packages/adapter-utils/
COPY packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY packages/adapters/gemini-local/package.json packages/adapters/gemini-local/
COPY packages/adapters/openclaw-gateway/package.json packages/adapters/openclaw-gateway/
COPY packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY packages/adapters/pi-local/package.json packages/adapters/pi-local/
COPY packages/plugins/sdk/package.json packages/plugins/sdk/
COPY patches/ patches/

RUN bun install --frozen-lockfile

# ============================================================
# Stage 2: Build
# ============================================================
FROM base AS build
WORKDIR /app
COPY --from=deps /app /app
COPY . .

# Build shared packages first
RUN bun run --filter @clawdev/shared build
RUN bun run --filter @clawdev/db build
RUN bun run --filter @clawdev/plugin-sdk build

# Build UI (SvelteKit static adapter)
RUN bun run --filter @clawdev/svelte-ui build

# Build server
RUN bun run --filter @clawdev/server build

# Verify build output
RUN test -f server/dist/index.js || (echo "ERROR: server build output missing" && exit 1)

# ============================================================
# Stage 3: Production
# ============================================================
FROM oven/bun:1.2-alpine AS production
RUN apk add --no-cache ca-certificates curl git

WORKDIR /app

# Copy built application
COPY --chown=bun:bun --from=build /app /app

# Install CLI tools globally
RUN bun install --global @anthropic-ai/claude-code@latest @openai/codex@latest opencode-ai \
  && mkdir -p /clawdev \
  && chown bun:bun /clawdev

ENV NODE_ENV=production \
  HOME=/clawdev \
  HOST=0.0.0.0 \
  PORT=3100 \
  SERVE_UI=true \
  CLAWDEV_HOME=/clawdev \
  CLAWDEV_INSTANCE_ID=default \
  CLAWDEV_CONFIG=/clawdev/instances/default/config.json \
  CLAWDEV_DEPLOYMENT_MODE=authenticated \
  CLAWDEV_DEPLOYMENT_EXPOSURE=private

VOLUME ["/clawdev"]
EXPOSE 3100

USER bun
CMD ["bun", "run", "server/dist/index.js"]
