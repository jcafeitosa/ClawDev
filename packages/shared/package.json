{
  "name": "@clawdev/shared",
  "version": "0.3.1",
  "license": "MIT",
  "homepage": "https://github.com/jcafeitosa/ClawDev",
  "bugs": {
    "url": "https://github.com/jcafeitosa/ClawDev/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jcafeitosa/ClawDev",
    "directory": "packages/shared"
  },
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./*": {
        "types": "./dist/*.d.ts",
        "import": "./dist/*.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
