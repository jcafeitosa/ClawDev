{
  "name": "@clawdev/plugin-file-browser-example",
  "version": "0.1.0",
  "description": "Example plugin: project sidebar Files link + project detail tab with workspace selector and file browser",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "clawdevPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "bun ../../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc && bun ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @clawdev/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@clawdev/plugin-sdk": "workspace:*",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
