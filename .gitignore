# ---------------------------------------------------------------------------
# AI / ML model files — NEVER commit these (they are large binary files)
# Applies globally to all subdirectories in this repo
# ---------------------------------------------------------------------------
# GGUF format (llama.cpp, Ollama, LM Studio)
*.gguf
# Safetensors format (HuggingFace, PyTorch)
*.safetensors
# PyTorch checkpoints
*.pt
*.pth
*.ckpt
# TensorFlow / Keras
*.pb
*.h5
*.tflite
# ONNX
*.onnx
# Bin weight shards (GGML, old HF format)
*.bin.index.json
# ---------------------------------------------------------------------------

